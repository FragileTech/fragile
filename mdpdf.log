   DEBUG: 2026-03-04 12:27:41,124:      pdf_renderer.py:  470: printSegment: \
   DEBUG: 2026-03-04 12:27:41,129:      pdf_renderer.py:  470: printSegment: frac{d
   DEBUG: 2026-03-04 12:27:41,133:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 12:27:41,137:      pdf_renderer.py:  470: printSegment: {
   DEBUG: 2026-03-04 12:27:41,142:      pdf_renderer.py:  470: printSegment: \
   DEBUG: 2026-03-04 12:27:41,147:      pdf_renderer.py:  470: printSegment: mathbb{P}}(z, c
   DEBUG: 2026-03-04 12:27:41,151:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 12:27:41,155:      pdf_renderer.py:  470: printSegment: k)}{
   DEBUG: 2026-03-04 12:27:41,160:      pdf_renderer.py:  470: printSegment: \
   DEBUG: 2026-03-04 12:27:41,164:      pdf_renderer.py:  470: printSegment: tau(z)}, 
   DEBUG: 2026-03-04 12:27:41,169:      pdf_renderer.py:  470: printSegment: \
   DEBUG: 2026-03-04 12:27:41,173:      pdf_renderer.py:  470: printSegment: quad 
   DEBUG: 2026-03-04 12:27:41,177:      pdf_renderer.py:  470: printSegment: \
   DEBUG: 2026-03-04 12:27:41,182:      pdf_renderer.py:  470: printSegment: tau(z) = 
   DEBUG: 2026-03-04 12:27:41,186:      pdf_renderer.py:  470: printSegment: \
   DEBUG: 2026-03-04 12:27:41,190:      pdf_renderer.py:  470: printSegment: frac{
   DEBUG: 2026-03-04 12:27:41,195:      pdf_renderer.py:  470: printSegment: \
   DEBUG: 2026-03-04 12:27:41,200:      pdf_renderer.py:  470: printSegment: sqrt{K}(1 - 
   DEBUG: 2026-03-04 12:27:41,204:      pdf_renderer.py:  470: printSegment: |
   DEBUG: 2026-03-04 12:27:41,208:      pdf_renderer.py:  470: printSegment: z
