   DEBUG: 2026-03-04 12:27:53,550:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 12:27:53,554:      pdf_renderer.py:  470: printSegment: geo (state), z
   DEBUG: 2026-03-04 12:27:53,558:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 12:27:53,562:      pdf_renderer.py:  470: printSegment: n (nuisance), z
   DEBUG: 2026-03-04 12:27:53,565:      pdf_renderer.py:  470: printSegment: _
   DEBUG: 2026-03-04 12:27:53,569:      pdf_renderer.py:  470: printSegment: tex
   DEBUG: 2026-03-04 12:27:53,573:      pdf_renderer.py:  470: printSegment: (texture) |
   DEBUG: 2026-03-04 12:27:53,577:      pdf_renderer.py:  470: printSegment:  
   DEBUG: 2026-03-04 12:27:53,581:      pdf_renderer.py:  470: printSegment: | 
   DEBUG: 2026-03-04 12:27:53,585:      pdf_renderer.py:  470: printSegment: Expert routing
   DEBUG: 2026-03-04 12:27:53,590:      pdf_renderer.py:  470: printSegment:  | Learned logits (black box) | Hyperbolic distance (geometric meaning) |
